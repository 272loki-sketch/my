modules = ["nodejs-24", "go-1.25"]
run = "cd new-api && ./new-api-bin --port 3000 --log-dir ./logs"

[deployment]
router = "application"
deploymentTarget = "gce"
build = ["sh", "-c", "cd new-api && test -f web/dist/index.html && go build -o new-api-bin . && chmod +x new-api-bin"]
run = ["sh", "-c", "cd new-api && ./new-api-bin --port 3000 --log-dir ./logs"]

[env]
GOPROXY = "https://goproxy.cn,direct"
CGO_ENABLED = "0"

[[ports]]
localPort = 3000
externalPort = 80
